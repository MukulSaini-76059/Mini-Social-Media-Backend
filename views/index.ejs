<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title> 
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <link rel="stylesheet" href="styles.css">
</head>
<body>
    <div class="w-full min-h-screen bg-zinc-900 text-white p-10 ">
        <h3 class="text-3xl mb-13 ">Create User</h3>
        <form method="post" action="/register" class="border-1 border-white rounded-md flex pt-7 pb-7 pl-8 ">
            <input class = "px-3 py-2 bg-transparent border-2 w-1/6 rounded-md border-zinc-800 outline-none" type="text" placeholder="Username" name="username">
            <input class = "px-3 py-2 bg-transparent border-2 w-1/6 rounded-md border-zinc-800 outline-none" type="email" placeholder="Email" name="email">
            <input class = "px-3 py-2 bg-transparent border-2 w-1/6 rounded-md border-zinc-800 outline-none" type="name" placeholder="Name" name="name">
            <input class = "px-3 py-2 bg-transparent border-2 w-1/6 rounded-md border-zinc-800 outline-none" type="number" placeholder="Age" name="age">
            <input class = "px-3 py-2 bg-transparent border-2 w-1/6 rounded-md border-zinc-800 outline-none" type="password" placeholder="Password" name="password">
            <input class ="px-5 py-2 rounded-md bg-blue-500" type="submit" value="Create User">
        </form>
    </div>
    
</body>
</html>