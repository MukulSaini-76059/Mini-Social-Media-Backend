<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title> 
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <link rel="stylesheet" href="styles.css">
</head>
<body>
    <div class="w-full min-h-screen bg-zinc-900 text-white p-7  ">
        <div class="w-full flex justify-end">
            <a class =" bg-red-500 rounded-md px-3 py-2 text-sm mb-5 inline-block" href="/logout">Logout</a>
        </div>
        <div class="flex items-start gap-3">
            <div class="w-10 h-10  rounded-md overflow-hidden ">
                <a href="/profile/upload"><img class="w-full h-full object-cover" src="/images/uploads/<%= user.profilePic %>" alt="" ></a>
            </div> 
            <h3 class="text-3xl mb-11"><span class=" font-light">Hello</span>, <%= user.name.toUpperCase()  %> 👋🏻</h3>
        </div>  
       
        <h5 class="mb-3"> You can Create a new post.</h5>
        <form method ="post" action="/post">
            <textarea placeholder="What's on your mind?" class="block w-1/3 p-3 outline-none resize-none bg-transparent border-2 border-zinc-600 rounded-md" name="content"></textarea>
            <input class="px-3 py-2 w-40 bg-blue-500 block rounded-md text-sm mt-2" type="submit" value="Create New Post">
        </form>
        <div class="posts mt-10">
            <h3 class="text-zinc-400">Your Posts.</h3>
            <div class="postcontainer mt-1">
                <% user.posts.reverse().forEach(function(post){ %>
                <div class="post w-1/3 p-2 border-2 border-zinc-600 rounded-md mb-4">
                    <h4 class="text-blue-500 mb-2 ">@<%= user.username %></h4>
                    <p class="text-lg tracking-tight pl-2"><%= post.content %></p>
                    <small class="mt-3  inline-block text-xs"><%= post.likes.length %> Likes</small>
                    <div class="btns flex justify-between  ">
                        <a class="text-blue-500 text-base " href="/like/<%= post._id %>">
                             <%= post.likes.indexOf(user._id) === -1 ? "Like": "Unlike" %></a>
                        <a class="text-zinc-400" href="/edit/<%= post._id %>">Edit</a>
                    </div>
                </div>
                <% }); %>
            </div>
        </div>
    </div>
    
</body>
</html>