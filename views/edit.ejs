<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title> 
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <link rel="stylesheet" href="styles.css">
</head>
<body>
    <div class="w-full min-h-screen bg-zinc-900 text-white p-7  ">
        <div class="w-full flex justify-end">
            <a class =" bg-red-500 rounded-md px-3 py-2 text-sm mb-5 inline-block" href="/logout">Logout</a>
        </div>
        <form method ="post" action="/update/<%= post._id %>">
           <h3 class="text-white text-2xl mb-8">Edit your post</h3>
           <textarea placeholder="What's on your mind?" class="block w-1/3 p-3 outline-none resize-none bg-transparent border-2 border-white rounded-md" name="content"><%= post.content %></textarea>
           <input class="px-3 py-2 w-40 bg-yellow-500 block rounded-md text-black text-sm mt-2" type="submit" value="Update Post">
        </form>
    </div>
    
</body>
</html>